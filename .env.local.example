# Google Drive Sync
# Copiez ce fichier en .env.local et ne le commitez jamais
# Obtenez ces valeurs sur https://console.cloud.google.com

# Client ID (public, utilisé côté client pour initier le flow OAuth)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=621001896902-dr840c29uc7nbte029som9ifel936ojj.apps.googleusercontent.com

# Client Secret (PRIVÉ — uniquement côté serveur, ne jamais préfixer par NEXT_PUBLIC_)
# À récupérer dans Google Cloud Console > APIs & Services > Credentials > votre OAuth client
GOOGLE_CLIENT_SECRET=VOTRE_CLIENT_SECRET_ICI

# Origine de l'application (sans slash final)
# Ex: http://localhost:3000 en développement, https://mylaw.vercel.app en production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Google Tasks + Google Calendar (intégrations tableau de bord) ────────
# Le même NEXT_PUBLIC_GOOGLE_CLIENT_ID que Drive peut être réutilisé, à
# condition d'ajouter les scopes Tasks + Calendar dans la configuration
# OAuth Google Cloud et d'ajouter cette redirection d'URI autorisée :
#   <NEXT_PUBLIC_APP_URL>/api/google-productivity/callback

# ─── Microsoft Graph (Outlook Mail — tableau de bord) ───────────────────
# Enregistrez une application Azure AD (Microsoft Entra) et renseignez :
#   - NEXT_PUBLIC_MICROSOFT_CLIENT_ID : « Application (client) ID »
#   - NEXT_PUBLIC_MICROSOFT_TENANT   : 'common' (multi-tenant), 'consumers'
#                                       pour comptes personnels, ou l'ID tenant
#   - MICROSOFT_CLIENT_SECRET        : secret si l'app est de type « Web »
#                                       (laisser vide pour SPA PKCE strict)
# URI de redirection autorisée à ajouter dans l'app Azure AD :
#   <NEXT_PUBLIC_APP_URL>/api/outlook/callback
# Scopes requis : offline_access Mail.Read User.Read
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=
NEXT_PUBLIC_MICROSOFT_TENANT=common
MICROSOFT_CLIENT_SECRET=
